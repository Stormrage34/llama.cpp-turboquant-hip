FROM rocm/dev-ubuntu-24.04:7.2.2
RUN apt-get update && apt-get install -y git cmake build-essential hipblas-dev rocblas-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY . .
RUN HIPCXX="$(hipconfig -l)/clang" HIP_PATH="$(hipconfig -R)" \
    cmake -S . -B build \
        -DGGML_HIP=ON \
        -DAMDGPU_TARGETS=gfx1100 \
        -DCMAKE_BUILD_TYPE=Release \
        -DLLAMA_BUILD_TESTS=OFF \
        -DLLAMA_BUILD_EXAMPLES=OFF \
        -DLLAMA_BUILD_SERVER=ON \
    && cmake --build build --config Release -j$(nproc) --target llama-server llama-bench llama-perplexity llama-completion
ENV LD_LIBRARY_PATH=/app/build/src:/app/build/ggml/src
