# TurboQuant llama-server configuration
# Copy to .env and edit

# Path to GGUF model inside container (mounted from MODELS_DIR)
MODEL_PATH=/models/model.gguf

# Host directory with GGUF models
MODELS_DIR=./models

# Server port
PORT=8080

# GPU target: gfx1030 (RDNA2), gfx1100 (RDNA3), gfx1200 (RDNA4)
GPU_TARGETS=gfx1100

# GPU device index (0 = first discrete GPU)
HIP_VISIBLE_DEVICES=0

# Number of layers offloaded to GPU (999 = all)
N_GPU_LAYERS=999

# KV cache type: f16, q8_0, turbo3, turbo4
CACHE_TYPE_K=turbo3
CACHE_TYPE_V=turbo3

# Context size
CTX_SIZE=8192

# Extra llama-server arguments
# Examples:
#   --cache-type-k-swa f16    (SWA bypass for Gemma 4)
#   --temp 0.6 --top-p 0.95   (sampling)
EXTRA_ARGS=
